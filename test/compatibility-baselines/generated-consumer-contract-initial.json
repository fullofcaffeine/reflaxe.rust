            {
              "id": "raw_codegen_fallback",
              "meaning": "group of raw code-generation fallback blockers"
            },
            {
              "id": "dynamic_boundary",
              "meaning": "group of Dynamic-compatible boundary blockers"
            },
            {
              "id": "policy_toggle",
              "meaning": "group of fallback-policy toggle blockers"
            },
            {
              "id": "uncategorized",
              "meaning": "blocker category that lacks an admitted typed issue-class mapping"
            }
          ]
        }
      ],
      "deterministicOrdering": [
        "globalBlockers and module blockers use weight-descending then id ordering",
        "issueClasses use total-weight-descending then id ordering",
        "modules use score-ascending then module-path ordering"
