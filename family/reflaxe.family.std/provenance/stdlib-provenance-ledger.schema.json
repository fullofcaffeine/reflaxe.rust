{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflaxe.family.std/schemas/stdlib-provenance-ledger.schema.json",
  "title": "reflaxe.family.std provenance ledger schema",
  "type": "object",
  "required": ["schema_version", "baseline", "entries"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "baseline": {
      "type": "object",
      "required": ["haxe_version"],
      "properties": {
        "haxe_version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "owner", "source"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
