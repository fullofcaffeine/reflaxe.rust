.DS_Store

# Node / lix
node_modules/
npm-debug.log*

# Rust build artifacts
target/
.cache/

# Generated outputs (kept in snapshots via `intended/`)
out/
**/out/
out_ci/
**/out_ci/
out_rusty/
**/out_rusty/
out_ci_rusty/
**/out_ci_rusty/

# Release artifacts
dist/

# Haxe
*.n
*.hl

# Haxe dumps (debugging)
dump/
**/dump/

# Python harness caches
__pycache__/
*.py[cod]

# Repomix bundles (local analysis artifacts)
repomix-output*.xml

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
