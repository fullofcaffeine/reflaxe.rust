{
  "name": "reflaxe-rust",
  "private": true,
  "version": "0.0.0-development",
  "license": "GPL-3.0",
  "description": "Haxe (4.3.7) → Rust target built on Reflaxe (dev toolchain via lix).",
  "engines": {
    "node": ">=22.14.0 <23"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "13.0.1",
