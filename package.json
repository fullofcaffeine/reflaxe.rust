    "test:template-smoke": "bash scripts/ci/template-smoke.sh",
    "test:codex-hxrust": "bash scripts/ci/check-codex-hxrust-smoke.sh",
    "test:cargo-failure-propagation": "bash scripts/ci/check-cargo-failure-propagation.sh",
    "test:timed-command-failure-propagation": "bash scripts/ci/check-timed-command-failure-propagation.sh",
