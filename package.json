    "ajv": "8.20.0",
    "conventional-changelog-conventionalcommits": "10.2.1",
    "fflate": "0.8.3",
    "lix": "15.12.4",
    "semantic-release": "25.0.5",
    "semver": "7.8.5"
  },
  "scripts": {
    "postinstall": "lix download",
    "test": "bash test/run-snapshots.sh",
    "test:update": "bash test/run-snapshots.sh --update",
    "test:watcher": "bash test/scripts/watch-haxe-rust.sh",
    "test:clean-artifacts": "bash test/scripts/clean-artifacts.sh",
    "test:release-policy": "node test/scripts/release-policy.test.js",
    "test:release-notes": "node test/scripts/release-notes.test.js",
    "test:release-artifact": "node test/scripts/release-artifact.test.js",
    "test:release-provenance": "node test/scripts/release-provenance.test.js",
    "test:release-workflow": "node test/scripts/release-workflow.test.js",
    "test:release-lifecycle": "node test/scripts/release-lifecycle.test.js",
    "test:runtime-e2e-contract": "node test/scripts/runtime-e2e-contract.test.js",
