    "test:all": "bash scripts/ci/harness.sh",
    "test:all:keep": "KEEP_ARTIFACTS=1 bash scripts/ci/harness.sh",
    "check:harness": "bash scripts/ci/harness.sh",
    "ci:local": "bash scripts/ci/local.sh",
    "dev:watch": "bash scripts/dev/watch-haxe-rust.sh",
    "dev:hx": "bash scripts/dev/cargo-hx.sh",
    "dev:new-project": "bash scripts/dev/new-project.sh",
    "clean:artifacts": "bash scripts/ci/clean-artifacts.sh --outputs",
    "clean:artifacts:all": "bash scripts/ci/clean-artifacts.sh --all",
    "security:gitleaks": "bash scripts/security/run-gitleaks.sh",
    "security:gitleaks:staged": "bash scripts/security/run-gitleaks.sh --staged",
    "test:pre-commit-evidence-wiring": "node test/scripts/pre-commit-evidence-wiring.test.js",
    "guard:upstream-stdlib-boundary": "node scripts/ci/upstream-stdlib-boundary-check.js",
    "guard:stdlib-ledger": "node scripts/ci/stdlib-provenance-ledger-check.js",
    "guard:portable-stdlib-allowlist": "node scripts/ci/portable-stdlib-allowlist-check.js",
    "guard:stdlib-candidates": "node scripts/ci/audit-upstream-stdlib-candidates.js --check",
    "guard:stdlib-candidate-gap": "node scripts/ci/check-portable-stdlib-candidate-gap.js",
    "guard:local-paths": "bash scripts/lint/local_path_guard_repo.sh",
    "guard:deprecated-defines": "bash scripts/lint/deprecated_define_guard.sh",
    "guard:defines-doc": "bash scripts/lint/defines_doc_guard.sh",
    "guard:security-wiring": "bash scripts/lint/security_wiring_guard.sh",
    "guard:release-policy": "node scripts/release/release-policy.js",
    "guard:native-facade-manifest": "node scripts/ci/native-facade-manifest-check.js",
    "guard:public-compatibility": "node scripts/ci/public-compatibility-manifest-check.js",
    "guard:generated-consumer-contract": "node scripts/ci/generated-consumer-contract-check.js",
    "guard:diagnostic-contract": "node scripts/ci/diagnostic-contract-check.js",
    "guard:rust-toolchain-policy": "node scripts/ci/rust-toolchain-policy.js --check",
    "toolchain:sync": "node scripts/ci/rust-toolchain-policy.js --write",
    "hooks:install": "bash scripts/install-git-hooks.sh",
    "hooks:check": "npm run guard:local-paths && npm run guard:tracked-artifacts && npm run guard:release-policy && npm run guard:upstream-stdlib-boundary && npm run guard:stdlib-ledger && npm run guard:native-facade-manifest && npm run guard:public-compatibility && npm run test:public-compatibility && npm run guard:generated-consumer-contract && npm run test:generated-consumer-contract && npm run guard:diagnostic-contract && npm run test:diagnostic-contract && npm run guard:rust-toolchain-policy && npm run test:rust-toolchain-policy && npm run guard:portable-stdlib-allowlist && npm run guard:stdlib-candidates && npm run guard:stdlib-candidate-gap && bash scripts/lint/name_heuristics_guard.sh && bash scripts/lint/numeric_suffix_guard.sh && bash scripts/lint/dynamic_usage_guard.sh && npm run guard:deprecated-defines && npm run guard:defines-doc && bash scripts/lint/cargo_hx_project_guard.sh && npm run guard:security-wiring && npm run test:pre-commit-evidence-wiring && npm run test:timed-command-failure-propagation && bash scripts/docs/check-progress-tracker.sh && npm run docs:check:navigation && npm run docs:check:evidence && npm run test:release && npm run test:watcher && npm run test:clean-artifacts",
    "hooks:check:full": "npm run guard:local-paths && npm run guard:tracked-artifacts && npm run guard:release-policy && npm run guard:upstream-stdlib-boundary && npm run guard:stdlib-ledger && npm run guard:native-facade-manifest && npm run guard:public-compatibility && npm run test:public-compatibility && npm run guard:generated-consumer-contract && npm run test:generated-consumer-contract && npm run guard:diagnostic-contract && npm run test:diagnostic-contract && npm run guard:rust-toolchain-policy && npm run test:rust-toolchain-policy && npm run guard:portable-stdlib-allowlist && npm run guard:stdlib-candidates && npm run guard:stdlib-candidate-gap && bash scripts/lint/name_heuristics_guard.sh && bash scripts/lint/numeric_suffix_guard.sh && bash scripts/lint/dynamic_usage_guard.sh && npm run guard:deprecated-defines && npm run guard:defines-doc && bash scripts/lint/cargo_hx_project_guard.sh && npm run guard:security-wiring && npm run test:pre-commit-evidence-wiring && npm run test:timed-command-failure-propagation && bash scripts/docs/check-progress-tracker.sh && npm run docs:check:navigation && npm run docs:check:evidence && npm run test:release && npm run test:clean-artifacts && npm run check:harness",
    "docs:sync:progress": "node scripts/docs/sync-progress-tracker.js",
    "docs:check:progress": "bash scripts/docs/check-progress-tracker.sh",
    "docs:check:navigation": "node scripts/docs/check-entrypoint-navigation.js",
    "docs:sync:evidence": "node scripts/ci/generate-semantic-confidence-summary.js --write",
    "docs:check:evidence": "bash scripts/ci/check-semantic-confidence-summary.sh",
    "docs:compatibility:refresh": "node scripts/ci/public-compatibility-manifest-check.js --refresh-manifest && node scripts/ci/public-compatibility-manifest-check.js --write-review",
    "docs:prep:closeout": "node scripts/docs/generate-release-gate-evidence.js",
    "guard:tracked-artifacts": "bash scripts/lint/tracked_artifact_guard.sh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fullofcaffeine/reflaxe.rust.git"
  }
}
