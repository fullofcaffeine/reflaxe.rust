#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"

echo "[pre-commit] Running local path guard on staged changes..."
bash "$ROOT_DIR/scripts/lint/local_path_guard_staged.sh"

if command -v bd >/dev/null 2>&1; then
  echo "[pre-commit] Running bd pre-commit hook (beads flush/staleness)..."
  bd hooks run pre-commit
else
  echo "[pre-commit] WARN: bd not found; skipping beads hook."
fi

echo "[pre-commit] Running gitleaks on staged changes..."
bash "$ROOT_DIR/scripts/security/run-gitleaks.sh" --staged

echo "[pre-commit] Running name-heuristics guard..."
"$ROOT_DIR/scripts/lint/name_heuristics_guard.sh"

echo "[pre-commit] Running numeric-suffix guard..."
"$ROOT_DIR/scripts/lint/numeric_suffix_guard.sh"

echo "[pre-commit] Running Dynamic usage guard..."
"$ROOT_DIR/scripts/lint/dynamic_usage_guard.sh"

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR || true)"
if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(docs/|README\.md$|\.beads/issues\.jsonl$|scripts/docs/)'; then
  echo "[pre-commit] Running docs progress-tracker drift check..."
  "$ROOT_DIR/scripts/docs/check-progress-tracker.sh"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(test/semantic_diff/|test/semantic_diff_lanes/|test/snapshot/|scripts/ci/generate-semantic-confidence-summary\.js$|docs/semantic-confidence-summary\.(json|md)$)'; then
  echo "[pre-commit] Running semantic-confidence evidence drift check..."
  for artifact in docs/semantic-confidence-summary.json docs/semantic-confidence-summary.md; do
    if ! git diff --quiet -- "$artifact"; then
      echo "[pre-commit] ERROR: ${artifact} has unstaged changes; regenerate and stage both semantic-confidence artifacts." >&2
      exit 1
    fi
  done
  "$ROOT_DIR/scripts/ci/check-semantic-confidence-summary.sh"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(README\.md$|docs/faq\.md$|docs/architecture-capability(-manifest\.json|\.md)$|scripts/ci/architecture-capability-manifest\.js$|test/scripts/architecture-capability-manifest\.test\.js$)'; then
  echo "[pre-commit] Running architecture capability claim drift check..."
  for artifact in docs/architecture-capability-manifest.json README.md docs/faq.md docs/architecture-capability.md; do
    if ! git diff --quiet -- "$artifact"; then
      echo "[pre-commit] ERROR: ${artifact} has unstaged changes; regenerate and stage all architecture capability consumers." >&2
      exit 1
    fi
  done
  node "$ROOT_DIR/scripts/ci/architecture-capability-manifest.js" --check
fi

echo "[pre-commit] OK"
