#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"

installed_repo_hook="$ROOT_DIR/.git/hooks/pre-commit"
if [[ -f "$installed_repo_hook" ]] \
  && ! cmp -s "$ROOT_DIR/scripts/hooks/pre-commit" \
    <(sed -n '1,/^# --- END REFLAXE\.RUST REPOSITORY PRE-COMMIT ---$/p' "$installed_repo_hook"); then
  echo "[pre-commit] ERROR: installed repository hook is stale; run npm run hooks:install and retry." >&2
  exit 1
fi

echo "[pre-commit] Running local path guard on staged changes..."
bash "$ROOT_DIR/scripts/lint/local_path_guard_staged.sh"

echo "[pre-commit] Running gitleaks on staged changes..."
bash "$ROOT_DIR/scripts/security/run-gitleaks.sh" --staged

echo "[pre-commit] Running name-heuristics guard..."
"$ROOT_DIR/scripts/lint/name_heuristics_guard.sh"

echo "[pre-commit] Running numeric-suffix guard..."
"$ROOT_DIR/scripts/lint/numeric_suffix_guard.sh"

echo "[pre-commit] Running Dynamic usage guard..."
"$ROOT_DIR/scripts/lint/dynamic_usage_guard.sh"

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR || true)"
if grep -Eq '^(docs/|README\.md$|\.beads/issues\.jsonl$|scripts/docs/)' <<<"$STAGED_FILES"; then
  echo "[pre-commit] Running docs progress-tracker drift check..."
  "$ROOT_DIR/scripts/docs/check-progress-tracker.sh"
fi

if grep -Eq '^(test/semantic_diff/|test/semantic_diff_lanes/|test/snapshot/|scripts/ci/generate-semantic-confidence-summary\.js$|docs/semantic-confidence-summary\.(json|md)$)' <<<"$STAGED_FILES"; then
  echo "[pre-commit] Running semantic-confidence evidence drift check..."
  for artifact in docs/semantic-confidence-summary.json docs/semantic-confidence-summary.md; do
    if ! git diff --quiet -- "$artifact"; then
      echo "[pre-commit] ERROR: ${artifact} has unstaged changes; regenerate and stage both semantic-confidence artifacts." >&2
      exit 1
    fi
  done
  "$ROOT_DIR/scripts/ci/check-semantic-confidence-summary.sh"
fi

if grep -Eq '^(README\.md$|docs/faq\.md$|docs/architecture-capability(-manifest\.json|\.md)$|scripts/ci/architecture-capability-manifest\.js$|test/scripts/architecture-capability-manifest\.test\.js$)' <<<"$STAGED_FILES"; then
  echo "[pre-commit] Running architecture capability claim drift check..."
  for artifact in docs/architecture-capability-manifest.json README.md docs/faq.md docs/architecture-capability.md; do
    if ! git diff --quiet -- "$artifact"; then
      echo "[pre-commit] ERROR: ${artifact} has unstaged changes; regenerate and stage all architecture capability consumers." >&2
      exit 1
    fi
  done
  node "$ROOT_DIR/scripts/ci/architecture-capability-manifest.js" --check
fi

if grep -Eq '^(scripts/(install-git-hooks\.sh|dev/sync-template-hook-installer\.js|hooks/pre-commit)$|templates/basic/scripts/(install-git-hooks\.sh|hooks/pre-commit)$|test/scripts/(git-hook-installation|pre-commit-evidence-wiring)\.test\.js$)' <<<"$STAGED_FILES"; then
  echo "[pre-commit] Verifying evidence-gate wiring..."
  npm --prefix "$ROOT_DIR" run hooks:check-template
  npm --prefix "$ROOT_DIR" run test:git-hook-installation
  npm --prefix "$ROOT_DIR" run test:pre-commit-evidence-wiring
fi

if grep -Eq '^(package\.json$|scripts/(ci/harness\.sh|hooks/pre-commit)$|src/reflaxe/rust/(RustCompiler|ast/RustAST|ast/RustASTPrinter|macros/RustInjection|passes/(NormalizePass|MetalRestrictionsPass|NoHxrtPass|StatementCleanupPass))\.hx$|std/rust/metal/Code\.hx$|test/compiler/RustRawAuthorityContract\.hx$|test/scripts/(pre-commit-evidence-wiring|rust-raw-authority)\.test\.js$)' <<<"$STAGED_FILES"; then
  echo "[pre-commit] Running typed raw-Rust authority contract..."
  npm --prefix "$ROOT_DIR" run test:rust-raw-authority
fi

if grep -Eq '^(package\.json$|scripts/(ci/harness\.sh|hooks/pre-commit)$|src/reflaxe/rust/(naming/RustNaming|ast/RustAST|ast/RustASTPrinter)\.hx$|test/compiler/RustStructuralPathContract\.hx$|test/scripts/(pre-commit-evidence-wiring|rust-structural-path-ir)\.test\.js$)' <<<"$STAGED_FILES"; then
  echo "[pre-commit] Running structural Rust path IR contract..."
  npm --prefix "$ROOT_DIR" run test:rust-structural-path-ir
fi

if grep -Eq '^(package\.json$|scripts/(ci/harness\.sh|hooks/pre-commit)$|src/reflaxe/rust/(RustCompiler|ast/RustAST|ast/RustASTPrinter|metadata/RustMetadataSyntax)\.hx$|test/compiler/RustStructuralTypeDeclarationContract\.hx$|test/scripts/(pre-commit-evidence-wiring|rust-structural-type-declarations)\.test\.js$)' <<<"$STAGED_FILES"; then
  echo "[pre-commit] Running structural Rust type declaration contract..."
  npm --prefix "$ROOT_DIR" run test:rust-structural-type-declarations
fi

echo "[pre-commit] OK"

# The Beads-managed integration is appended below this boundary by
# scripts/install-git-hooks.sh. It is the sole owner of `bd hooks run`; keeping
# repository validation inside this bounded prefix prevents recursive chains.
# Disable errexit so Beads' generated timeout/status handling can observe and
# normalize its command status before deciding whether the hook should fail.
set +e
# --- END REFLAXE.RUST REPOSITORY PRE-COMMIT ---
