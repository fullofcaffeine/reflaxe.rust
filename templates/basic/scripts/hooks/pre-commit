#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

echo "[pre-commit] Running local path guard on staged changes..."
bash "$ROOT_DIR/scripts/lint/local_path_guard_staged.sh"

echo "[pre-commit] Running gitleaks on staged changes..."
bash "$ROOT_DIR/scripts/security/run-gitleaks.sh" --staged

echo "[pre-commit] OK"

# The Beads-managed integration is appended below this boundary by
# scripts/install-git-hooks.sh. It is the sole owner of `bd hooks run`; keeping
# repository validation inside this bounded prefix prevents recursive chains.
# Disable errexit so Beads' generated timeout/status handling can observe and
# normalize its command status before deciding whether the hook should fail.
set +e
# --- END REFLAXE.RUST REPOSITORY PRE-COMMIT ---
